# 1Password Service Account token
# Create at: https://my.1password.com/developer-tools/infrastructure-secrets/serviceaccount/
OP_SERVICE_ACCOUNT_TOKEN=ops_your_token_here

# Azure Key Vault URL
AZURE_KEY_VAULT_URL=https://your-vault-name.vault.azure.net

# Azure credentials (only needed locally if not using `az login`)
# In AKS, these are injected automatically via Workload Identity
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_TENANT_ID=your-tenant-id
